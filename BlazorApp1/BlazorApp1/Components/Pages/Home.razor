<style>
	#hiddenContent {
		padding: 0;
		box-sizing: border-box;
	}

	html, body {
		height: 100%;
		min-height: 100%;
		margin: 0;
		padding: 0;
	}

	body {
		background-image: url('ChatGPTMusic.png');
		background-size: cover;
		background-repeat: no-repeat;
		background-position: center -113px;
		background-attachment: fixed;
		background-color: #f0f0f0;
		font-family: 'Times New Roman', Times, serif;
		font-size: 18px;
		min-height: 100vh;
		color: skyblue;
		box-sizing: border-box;
	}

	.bubble {
		display: inline-block;
		background: rgba(15, 191, 214, 0.8);
		color: #222;
		padding: 8px 16px;
		border-radius: 20px;
		margin: 6px 4px;
		font-size: 16px;
		box-shadow: 1px 2px 8px rgba(0, 0, 0, 0.08);
	}

	p {
		font-size: 22px;
	}

	table, th, td {
		border: 2px solid rgb(0, 0, 0);
	}

	table {
		width: 100%;
		border-collapse: collapse;
	}

	.info-flex {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 40px;
		margin-bottom: 32px;
		align-items: stretch;
	}

	.info-box {
		background: rgba(240, 38, 38, 0);
		color: skyblue;
		border: 2px solid #0fbfd6;
		border-radius: 16px;
		padding: 20px;
		min-width: 0;
		max-width: none;
		box-sizing: border-box;
		height: 100%;
		box-shadow: 1px 2px 8px rgba(42, 141, 47, 0.733);
	}

	.info-box h2 {
		margin-top: 0;
		white-space: nowrap;
	}

	.info-box details {
		margin-top: 12px;
	}

	.info-box details summary {
		cursor: pointer;
		position: relative;
		font-weight: bold;
		transition: color 0.3s;
		list-style-type: none;
		outline: none;
	}

	.info-box details summary::-webkit-details-marker {
		display: none;
	}

	.info-box details > summary {
		list-style: none;
		list-style-type: none;
		outline: none;
		padding-left: 0;
	}

	.info-box details summary::after {
		content: "▼";
		display: inline-block;
		margin-left: 8px;
		transition: transform 0.3s;
	}

	.info-box details[open] summary::after {
		transform: rotate(180deg);
	}

	#carousel-container {
		text-align: center;
		margin: 48px auto;
		width: 560px;
		height: 380px;
		position: relative;
		display: flex;
		flex-direction: column;
		justify-content: center;
	}

	#carousel-image-container {
		width: 540px;
		height: 340px;
		border-radius: 16px;
		background: #000000;
		border: none;
		padding: 16px;
		box-sizing: border-box;
		display: flex;
		align-items: center;
		justify-content: center;
		background-image: url('Topograph.jpg'), repeating-radial-gradient(circle at 30% 30%, red 0%, orange 15%, yellow 30%, green 45%, cyan 60%, blue 75%, violet 90%, red 100%);
		background-size: 200% 200%, 1200% 1200%;
		background-position: center, 0% 0%;
		background-blend-mode: lighten;
		animation: rgbSmokeRandom 60s linear infinite;
		filter: blur(0.5px);
	}

	#carousel-image {
		width: 100%;
		height: 100%;
		object-fit: contain;
		border-radius: 8px;
		background: transparent;
		padding: 0;
		box-sizing: border-box;
		transition: transform 0.4s;
	}

	@@keyframes rgbSmokeRandom {
		0% {
			background-position: center, 0% 0%;
		}

		100% {
			background-position: center, 100% 100%;
		}
	}

	#carousel-container button,
	.action-btn {
		padding: 8px 16px;
		border-radius: 8px;
		border: none;
		background: #222;
		color: #0fbfd6;
		font-weight: bold;
		cursor: pointer;
		margin: 0 8px;
		transition: background 0.2s;
	}

	#carousel-container button:hover,
	.action-btn:hover {
		background: #444;
	}

	@@media (max-width: 1100px) {
		.info-flex {
			grid-template-columns: 1fr;
		}

		.info-box {
			max-width: 100%;
		}
	}

	@@media (max-width: 700px) {
		.info-box h2 {
			white-space: normal;
		}

		#carousel-container {
			width: 100%;
			height: auto;
		}

		#carousel-image-container {
			width: 100%;
			height: 260px;
			padding: 10px;
		}

		p {
			font-size: 18px;
		}
	}
</style>

@code {
	private readonly string[] CarouselImages =
	{
		"Devteam4.jpeg",
		"Devteam5.jpeg",
		"Devteam6.jpeg",
		"Devteam7.jpeg",
		"Devteam8.jpeg",
		"Devteam9.jpeg",
		"Devteam10.jpeg",
		"Devteam11.jpeg",
		"Devteam12.jpeg"
	};

	private int currentImageIndex;
	private Timer? carouselTimer;

	protected override void OnInitialized()
	{
		carouselTimer = new Timer(_ =>
		{
			_ = InvokeAsync(() =>
			{
				currentImageIndex = (currentImageIndex + 1) % CarouselImages.Length;
				StateHasChanged();
			});
		}, null, 4000, 4000);
	}

	private void PrevImage()
	{
		currentImageIndex = (currentImageIndex - 1 + CarouselImages.Length) % CarouselImages.Length;
	}

	private void NextImage()
	{
		currentImageIndex = (currentImageIndex + 1) % CarouselImages.Length;
	}

	public void Dispose()
	{
		carouselTimer?.Dispose();
	}
}
